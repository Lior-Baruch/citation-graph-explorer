# Copy this file to ".env" and fill in your keys.
# Both keys are OPTIONAL — the app runs fully without them.

# Enables LLM cluster labels + lineage narration. Without it those features
# are gracefully disabled and the UI says so.
ANTHROPIC_API_KEY=

# Optional Semantic Scholar API key. Without it the backend throttles to
# <= 1 request/second. With it, throughput is raised.
S2_API_KEY=
